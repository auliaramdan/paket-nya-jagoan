  conversationText:
    stringRef: {fileID: 0}
    stringVal: 'Blue avatars_01 left >>>: Pagi, disini ada orang tidak?

      Red
      avatars_08 right <<<: Yang lain masih pada tidur. Ada apa?

      Blue: Ada
      yang bisa bantu bukain jalan?

      Red: Jalan? Ke mana?

      Red hide:
      Tunggu besok.

      Blue hide: Plis? Aku gak bisa pulang sampai bisa jalan
      nya terbuka.'
